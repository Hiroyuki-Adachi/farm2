<div class="container py-3">
  <h1 class="h3 mb-3">人員保守</h1>
  <p class="text-muted mb-3">
    <%= @schedule.worked_at %> <%= @schedule.name %>
  </p>

  <%= form_with url: personal_information_schedules_workers_edit_path(personal_information_token: params[:personal_information_token], schedule_id: @schedule.id), method: :patch do %>
    <h2 class="h5 mb-2"><%= @section_worker_management ? "自班の作業者" : "世帯の作業者" %></h2>
    <div class="list-group mb-4">
      <% @workers.each do |worker| %>
        <label class="list-group-item d-flex align-items-center gap-2">
          <%= check_box_tag "worker_ids[]", worker.id, @selected_worker_ids.include?(worker.id), class: "form-check-input" %>
          <span><%= worker.name %></span>
        </label>
      <% end %>
    </div>

    <% if @supporter_sections.present? %>
      <h2 class="h5 mb-2">他班から追加</h2>
      <div class="mb-4">
        <% @supporter_sections.each do |section| %>
          <% collapse_id = "supporter_section_#{section.id}" %>
          <% section_worker_ids = @supporter_workers_by_section[section].map(&:id) %>
          <% expanded = (section_worker_ids & @selected_worker_ids).present? %>
          <div class="mb-2">
            <button class="btn btn-outline-primary w-100 text-start" type="button" data-bs-toggle="collapse" data-bs-target="#<%= collapse_id %>" aria-expanded="<%= expanded %>" aria-controls="<%= collapse_id %>">
              <%= section.name %>
            </button>
            <div class="collapse mt-2<%= ' show' if expanded %>" id="<%= collapse_id %>">
              <div class="list-group">
                <% @supporter_workers_by_section[section].each do |worker| %>
                  <label class="list-group-item d-flex align-items-center gap-2">
                    <%= check_box_tag "worker_ids[]", worker.id, @selected_worker_ids.include?(worker.id), class: "form-check-input" %>
                    <span><%= worker.name %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="text-center mb-3">
      <div class="btn-group" role="group">
        <%= submit_tag "登録", class: "btn btn-warning" %>
        <%= link_to "戻る", personal_information_schedules_workers_path(personal_information_token: params[:personal_information_token]), class: "btn btn-outline-dark" %>
      </div>
    </div>
  <% end %>
</div>
