<h1>統合農薬マスタ照会</h1>

<table class="table table-sm">
  <tbody>
    <tr>
      <th>登録番号</th>
      <td><%= @pesticide_master.registration_number %></td>
    </tr>
    <tr>
      <th>農薬名</th>
      <td><%= @pesticide_master.name %></td>
    </tr>
    <tr>
      <th>農薬名(正規化)</th>
      <td><%= @pesticide_master.name_normalized %></td>
    </tr>
    <tr>
      <th>農薬の種類</th>
      <td><%= @pesticide_master.pesticide_kind %></td>
    </tr>
    <tr>
      <th>農薬の種類(正規化)</th>
      <td><%= @pesticide_master.pesticide_kind_normalized %></td>
    </tr>
    <tr>
      <th>用途</th>
      <td><%= @pesticide_master.usage %></td>
    </tr>
    <tr>
      <th>剤型名</th>
      <td><%= @pesticide_master.formulation_name %></td>
    </tr>
    <tr>
      <th>剤型名(正規化)</th>
      <td><%= @pesticide_master.formulation_name_normalized %></td>
    </tr>
    <tr>
      <th>登録者</th>
      <td><%= @pesticide_master.registrant_name %></td>
    </tr>
    <tr>
      <th>登録者(正規化)</th>
      <td><%= @pesticide_master.registrant_name_normalized %></td>
    </tr>
    <tr>
      <th>混合数</th>
      <td><%= @pesticide_master.mixture_count %></td>
    </tr>
    <tr>
      <th>登録年月日</th>
      <td><%= @pesticide_master.registered_on %></td>
    </tr>
    <tr>
      <th>紐づく現行農薬数</th>
      <td><%= @pesticide_master.chemicals.count %></td>
    </tr>
  </tbody>
</table>

<div class="btn-toolbar">
  <div class="btn-group mr-2">
    <%= link_to "一覧へ戻る", pesticide_masters_path, class: "btn btn-outline-dark" %>
  </div>
</div>
