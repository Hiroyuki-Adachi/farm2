<h1 data-controller="page-loader" data-page-loader-modules-value="pages/sorimachi">ソリマチ農業簿記(<%= current_term %>)</h1>
<% if @error %>
<div class="alert alert-danger" role="alert"><%= @error %></div>
<% end %>
<% if @total_cost_types.present? %>
<%= form_with(url: sorimachi_imports_path, method: :get, local: true, class: "mb-3") do %>
  <div class="btn-group" role="group" aria-label="原価種別">
    <% @total_cost_types.each do |total_cost_type| %>
      <%= radio_button_tag :total_cost_type_id, total_cost_type.id, @selected_total_cost_type_id == total_cost_type.id, id: "total_cost_type_#{total_cost_type.id}", class: "btn-check", autocomplete: "off", onchange: "this.form.submit();" %>
      <%= label_tag "total_cost_type_#{total_cost_type.id}", total_cost_type.name, class: "btn btn-outline-primary" %>
    <% end %>
  </div>
<% end %>
<% end %>
<% if @total_cost_types.present? %>
<table class="table table-sm">
  <thead>
    <tr>
      <th class="numeric">番号</th>
      <th>日付</th>
      <th>科目</th>
      <th class="numeric">金額</th>
      <th>備考</th>
    </tr>
  </thead>
  <tbody>
  <% @journal_rows.each do |row| %>
    <tr id="tr_<%= row[:id] %>" class="<%= row[:unallocated] ? 'table-warning' : '' %>">
      <td class="numeric"><%= row[:line] %>-<%= row[:detail] %></td>
      <td><%= row[:accounted_on] ? row[:accounted_on].strftime('%m月%d日') : "決算" %></td>
      <td><%= row[:account_name] %></td>
      <td class="numeric"><%= number_to_currency(row[:amount], {precision: 0, unit: ""}) %></td>
      <td><%= row[:remark1] %><%= row[:remark3].present? ? "／#{row[:remark3]}" : "" %></td>
    </tr>
  <% end %>
  </tbody>
</table>
<%= paginate(@journals) %>
<% end %>
<%= form_with(url: sorimachi_imports_path, data: {turbo_confirm: "取り込みを実行してもよろしいですか？"}, html: {multipart: true}) do |f| %>
  <div class="row">
    <div class="col-md-4 form-group">
      <%= file_field_tag :import_file, {class: "form-control-file custom-file-input", data: {buttonText: "ファイル選択"}} %>
    </div>
  </div>
  <div class="btn-toolbar" role="toolbar">
    <div class="btn-group mr-2" role="group">
      <%= submit_tag 'インポート', class: "btn btn-danger", data: {wait: true} %>
      <%= link_to "自動配賦", auto_allocate_sorimachi_imports_path(total_cost_type_id: @selected_total_cost_type_id), {class: "btn btn-warning", data: {turbo_method: :post, turbo_confirm: "自動配賦を実行してもよろしいですか？", wait: true}} %>
      <%= button_tag "簡易集計", type: :button, id: :total_button, class: "btn btn-info", data: {url: sorimachi_totals_path(total_cost_type_id: @selected_total_cost_type_id) } %>
    </div>
    <div class="btn-group mr-2" role="group">
      <%= link_to "戻る", menu_index_path, {class: "btn btn-outline-dark"}%>
    </div>
  </div>
<% end %>
<div class="modal fade" id="total_modal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-xl" role="document" style="max-width: 95vw;">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">科目別簡易集計</h5>
      </div>
      <div class="modal-body" id="total_body">
      </div>
      <div class="modal-footer">
        <button id="total_close" type="button" class="btn btn-secondary">閉じる</button>
      </div>
    </div>
  </div>
</div>
