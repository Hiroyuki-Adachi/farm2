<h1><%= @fixed_at.strftime('%Y年 %m月') %>確定分 全銀データ</h1>

<% create_label = @batch ? "全銀データ再作成" : "全銀データ作成" %>
<% create_confirm = @batch ? "作成済みの全銀データを削除して再作成します。手入力・取込済みの明細も削除されます。よろしいですか？" : "この確定分の全銀データを作成します。よろしいですか？" %>
<div class="btn-toolbar mb-3">
  <div class="btn-group mr-2">
    <%= button_to create_label, fix_zengin_payment_path(@fix), method: :post, class: "btn btn-warning", form: {data: {turbo_confirm: create_confirm}} %>
  </div>
  <div class="btn-group mr-2">
    <%= link_to "CSVひな形", land_fee_template_fix_zengin_payment_path(@fix), class: "btn btn-outline-success" %>
  </div>
  <% if @batch %>
    <div class="btn-group mr-2">
      <%= button_to "育苗費取込", seedling_fee_import_fix_zengin_payment_path(@fix), method: :post, class: "btn btn-outline-primary", form: {data: {turbo_confirm: "育苗費を取り込みます。既存の育苗費取込分は削除して入れ直します。よろしいですか？"}} %>
    </div>
    <div class="btn-group mr-2">
      <%= button_to "乾燥調整費取込", drying_adjustment_fee_import_fix_zengin_payment_path(@fix), method: :post, class: "btn btn-outline-primary", form: {data: {turbo_confirm: "乾燥調整費を取り込みます。既存の乾燥調整費取込分は削除して入れ直します。よろしいですか？"}} %>
    </div>
  <% end %>
</div>

<% if @batch %>
  <%= form_with url: export_fix_zengin_payment_path(@fix), method: :post, data: {turbo: false}, class: "mb-3" do |f| %>
    <div class="row g-2 align-items-center">
      <div class="col-auto">
        <%= f.label :transfer_on, "振込指定日", class: "col-form-label" %>
      </div>
      <div class="col-auto">
        <%= f.date_field :transfer_on, value: Time.zone.today, min: Time.zone.today, required: true, class: "form-control" %>
      </div>
      <div class="col-auto">
        <%= f.submit "全銀ファイル出力", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>

  <%= form_with url: land_fee_import_fix_zengin_payment_path(@fix), method: :post, html: {multipart: true}, data: {turbo_confirm: "CSVを取り込みます。既存のCSV取込分は削除して入れ直します。よろしいですか？"}, class: "mb-3" do |f| %>
    <div class="row g-2 align-items-center">
      <div class="col-auto">
        <%= f.file_field :land_fee_file, accept: ".csv,text/csv", required: true, class: "form-control" %>
      </div>
      <div class="col-auto">
        <%= f.submit "CSV取込", class: "btn btn-success" %>
      </div>
    </div>
  <% end %>
<% end %>

<% if @batch %>
  <div class="row mb-3">
    <div class="col-md-3">
      <div class="fw-bold">委託者コード</div>
      <div><%= @batch.consignor_code.presence || '-' %></div>
    </div>
    <div class="col-md-3">
      <div class="fw-bold">委託者名</div>
      <div><%= @batch.consignor_name.presence || '-' %></div>
    </div>
    <div class="col-md-3">
      <div class="fw-bold">仕向口座</div>
      <div><%= [@batch.bank_code, @batch.branch_code, @batch.account_number].reject(&:blank?).join(' / ').presence || '-' %></div>
    </div>
    <div class="col-md-3">
      <div class="fw-bold">状態</div>
      <div><%= @batch.status %></div>
    </div>
  </div>

  <% payment_columns = [
    ["daily_wage", "日当"],
    ["machine_rental_fee", "機械賃借料"],
    ["seedling_fee", "育苗費"],
    ["drying_adjustment_fee", "乾燥調整費"]
  ] %>
  <% other_payment_column = ["other", "その他"] %>
  <% payments = @batch.zengin_payments.select { |payment| payment.worker.home.member_flag? }.sort_by { |payment| [payment.worker.home.finance_order || 9999, payment.worker.home.id, payment.worker.display_order || 9999, payment.worker.id] } %>
  <% imported_labels = payments.flat_map { |payment| payment.zengin_payment_details.select(&:source_kind_imported?).map(&:source_label) }.compact.uniq %>
  <% payment_totals = Hash.new(0) %>
  <% imported_totals = Hash.new(0) %>
  <% grand_total = 0 %>

  <table class="table table-sm">
    <thead>
      <tr>
        <th>会計ID</th>
        <th>世帯</th>
        <th>支払先</th>
        <% payment_columns.each do |_payment_type, label| %>
          <th class="numeric"><%= label %></th>
        <% end %>
        <% imported_labels.each do |label| %>
          <th class="numeric"><%= label %></th>
        <% end %>
        <th class="numeric"><%= other_payment_column.last %></th>
        <th class="numeric">合計</th>
      </tr>
    </thead>
    <tbody>
      <% payments.each do |payment| %>
        <% details = payment.zengin_payment_details.group_by(&:payment_type) %>
        <% row_total = payment.amount.to_i %>
        <% grand_total += row_total %>
        <tr class="<%= 'table-warning' if payment.account_incomplete? %>">
          <td><%= payment.worker.home.finance_order %></td>
          <td><%= payment.worker.home.name %></td>
          <td><%= payment.worker.name %></td>
          <% payment_columns.each do |payment_type, _label| %>
            <% amount = details.fetch(payment_type, []).reject(&:source_kind_imported?).sum(&:amount).to_i %>
            <% payment_totals[payment_type] += amount %>
            <td class="numeric <%= 'text-danger' if amount.negative? %>"><%= number_with_delimiter(amount) %></td>
          <% end %>
          <% imported_labels.each do |label| %>
            <% amount = payment.zengin_payment_details.select { |detail| detail.source_kind_imported? && detail.source_label == label }.sum(&:amount).to_i %>
            <% imported_totals[label] += amount %>
            <td class="numeric <%= 'text-danger' if amount.negative? %>"><%= number_with_delimiter(amount) %></td>
          <% end %>
          <% other_amount = details.fetch(other_payment_column.first, []).reject(&:source_kind_imported?).sum(&:amount).to_i %>
          <% payment_totals[other_payment_column.first] += other_amount %>
          <td class="numeric <%= 'text-danger' if other_amount.negative? %>"><%= number_with_delimiter(other_amount) %></td>
          <td class="numeric <%= 'text-danger' if row_total.negative? %>"><%= number_with_delimiter(row_total) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr>
        <th colspan="3">合計</th>
        <% payment_columns.each do |payment_type, _label| %>
          <% total_amount = payment_totals[payment_type] %>
          <th class="numeric <%= 'text-danger' if total_amount.negative? %>"><%= number_with_delimiter(total_amount) %></th>
        <% end %>
        <% imported_labels.each do |label| %>
          <% total_amount = imported_totals[label] %>
          <th class="numeric <%= 'text-danger' if total_amount.negative? %>"><%= number_with_delimiter(total_amount) %></th>
        <% end %>
        <% other_total_amount = payment_totals[other_payment_column.first] %>
        <th class="numeric <%= 'text-danger' if other_total_amount.negative? %>"><%= number_with_delimiter(other_total_amount) %></th>
        <th class="numeric <%= 'text-danger' if grand_total.negative? %>"><%= number_with_delimiter(grand_total) %></th>
      </tr>
    </tfoot>
  </table>
<% else %>
  <div class="alert alert-info">
    この確定分の全銀データはまだ作成されていません。
  </div>

  <table class="table table-sm">
    <thead>
      <tr>
        <th>会計ID</th>
        <th>世帯</th>
        <th>支払先</th>
        <th class="numeric">日当</th>
        <th class="numeric">機械賃借料</th>
        <th class="numeric">育苗費</th>
        <th class="numeric">乾燥調整費</th>
        <th class="numeric">その他</th>
        <th class="numeric">合計</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td colspan="8">上のボタンから全銀データを作成してください。</td>
      </tr>
    </tbody>
  </table>
<% end %>

<div class="btn-toolbar">
  <% if @batch %>
    <div class="btn-group mr-2">
      <%= link_to "保守", edit_fix_zengin_payment_path(@fix), class: "btn btn-success" %>
    </div>
  <% end %>
  <div class="btn-group mr-2">
    <%= link_to '戻る', fixes_path, class: "btn btn-outline-dark" %>
  </div>
</div>
