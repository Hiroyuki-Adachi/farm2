<% payment_type_labels = {
  "daily_wage" => "日当",
  "land_management_fee" => "農地管理料",
  "tenant_land_management_fee" => "小作地管理料",
  "machine_rental_fee" => "機械賃借料",
  "seedling_fee" => "育苗費",
  "drying_adjustment_fee" => "乾燥調整費",
  "other" => "その他"
} %>
<% payment_type = @details.first&.payment_type || "other" %>
<% daily_wage = payment_type == "daily_wage" %>
<% worker_names = @details.filter_map { |detail| @work_results[detail.source_id]&.worker&.name }.uniq %>
<% source_labels = @details.filter_map { |detail| detail.display_source_label.presence }.uniq %>
<% item_label = daily_wage ? worker_names.first : source_labels.first %>
<% item_label ||= payment_type_labels.fetch(payment_type, payment_type) %>

<%= turbo_frame_tag "zengin_payment_modal" do %>
  <div class="modal fade" id="zengin-payment-amount-modal" tabindex="-1" aria-hidden="true" data-controller="zengin-payment-modal">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">金額変更</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
        </div>

        <%= form_with url: amount_change_fix_zengin_payment_path(@fix), method: :patch, data: { turbo_frame: "_top" } do %>
          <%= hidden_field_tag :payment_id, @payment.id %>
          <%= hidden_field_tag :manual_entry, @manual_entry %>
          <% @details.each do |detail| %>
            <%= hidden_field_tag "detail_ids[]", detail.id %>
          <% end %>

          <div class="modal-body">
            <dl class="row mb-3">
              <dt class="col-sm-2">世帯</dt>
              <dd class="col-sm-4"><%= @payment.worker.home.name %></dd>
              <dt class="col-sm-2">支払先</dt>
              <dd class="col-sm-4"><%= @payment.worker.name %></dd>
              <dt class="col-sm-2">種別</dt>
              <dd class="col-sm-4"><%= payment_type_labels.fetch(payment_type, payment_type) %></dd>
              <dt class="col-sm-2">項目</dt>
              <dd class="col-sm-4"><%= item_label %></dd>
            </dl>

            <div class="alert alert-danger" role="alert">
              元データから支払金額を変更します。金額を変更する明細には、変更理由・備考を入力してください。
            </div>

            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th><%= daily_wage ? "作業日" : "元データ" %></th>
                    <th class="numeric">元金額</th>
                    <th class="numeric">現在額</th>
                    <th style="min-width: 9rem;">変更後金額</th>
                    <th style="min-width: 14rem;">変更理由・備考</th>
                  </tr>
                </thead>
                <tbody>
                  <% if @details.present? %>
                    <% @details.each do |detail| %>
                      <% work_result = @work_results[detail.source_id] %>
                      <tr class="<%= "table-warning" if detail.amount_modified? %>">
                        <td><%= work_result&.work&.worked_at || detail.display_source_label.presence || "-" %></td>
                        <td class="numeric"><%= number_with_delimiter(detail.original_amount.to_i) %></td>
                        <td class="numeric"><%= number_with_delimiter(detail.amount.to_i) %></td>
                        <td>
                          <%= number_field_tag "details[#{detail.id}][amount]", detail.amount.to_i,
                                class: "form-control form-control-sm text-end",
                                step: 1,
                                required: true %>
                        </td>
                        <td>
                          <%= text_field_tag "details[#{detail.id}][remarks]", detail.remarks,
                                class: "form-control form-control-sm",
                                maxlength: 120 %>
                        </td>
                      </tr>
                    <% end %>
                  <% else %>
                    <tr>
                      <td>その他</td>
                      <td class="numeric">0</td>
                      <td class="numeric">0</td>
                      <td>
                        <%= number_field_tag "details[new][amount]", nil,
                              class: "form-control form-control-sm text-end",
                              step: 1,
                              required: true,
                              autofocus: true %>
                      </td>
                      <td>
                        <%= text_field_tag "details[new][remarks]", nil,
                              class: "form-control form-control-sm",
                              maxlength: 120,
                              required: true %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">キャンセル</button>
            <%= submit_tag "金額を変更", class: "btn btn-danger" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
