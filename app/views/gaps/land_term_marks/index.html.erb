<h1 data-controller="page-loader" data-page-loader-modules-value="pages/gaps-land-term-marks">圃場記号(<%= current_term %>)</h1>

<%= error_print(@error_land_term_mark || @land_term_mark) %>

<table class="table table-sm align-middle">
  <thead>
    <tr>
      <th>記号</th>
      <th>圃場</th>
      <th>所有者</th>
      <th class="numeric">面積(α)</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @land_term_marks.each do |land_term_mark| %>
      <tr>
        <td style="width: 12rem;">
          <%= form_with model: [:gaps, land_term_mark], class: "d-flex gap-2" do |f| %>
            <%= f.text_field :mark, maxlength: 10, required: true, class: "form-control form-control-sm" %>
            <%= f.submit "更新", class: "btn btn-warning btn-sm" %>
          <% end %>
        </td>
        <td><%= land_term_mark.land.place %></td>
        <td><%= land_term_mark.land.owner_name %></td>
        <td class="numeric"><%= land_term_mark.land.area %></td>
        <td>
          <%= link_to "削除", gaps_land_term_mark_path(land_term_mark), {
            data: { turbo_confirm: "本当に削除してもよろしいですか?", turbo_method: :delete },
            class: "btn btn-danger btn-sm"
          } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= form_with model: [:gaps, @land_term_mark], html: { autocomplete: "off" } do |f| %>
  <div class="row align-items-end">
    <div class="field mb-3 col-md-5">
      <%= label_tag :land, "圃場", class: "col-form-label-lg form-label" %>
      <%= text_field_tag :land, nil, class: "form-control", autocomplete: :off %>
      <%= f.hidden_field :land_id, id: "land_term_mark_land_id" %>
    </div>
    <div class="field mb-3 col-md-2">
      <%= f.label :mark, class: "col-form-label-lg form-label" %>
      <%= f.text_field :mark, maxlength: 10, required: true, class: "form-control" %>
    </div>
    <div class="field mb-3 col-md-2">
      <%= f.submit "追加", class: "btn btn-success" %>
    </div>
  </div>
<% end %>

<div class="btn-toolbar">
  <div class="btn-group mr-2">
    <%= link_to "戻る", menu_index_path, class: "btn btn-outline-dark" %>
  </div>
</div>

<%= hidden_field_tag :autocomplete_land_term_marks_path, autocomplete_gaps_land_term_marks_path %>
